<% path = controller_path.include?("poison") ? wiki_poison_path(article.slug) : wiki_article_path(article.slug) %>

<%= link_to path, class: "wiki-item" do %>
  <%= article.title %>
  <%= tag.small "in #{ article.category.title }" unless params[:slug] %>

  <div class="wiki-item__tray">
    Last edited <%= time_ago_in_words(article.created_at) %> ago |
    <%= Wiki::Article.where(group_id: article.group_id).size %> edits
  </div>
<% end %>
